Important java.util.Scanner;

public class prime
{
     public static void main(String [] args) 
{
     Scanner.out.println("Enter a Number");
     int n = sc.nextInt();
     int count=0;
     for(int I = 1 ; I <=n ; I++) 
{
     if(n%i == 2) 
     count=count+1;
}
     if(count == 2) 
